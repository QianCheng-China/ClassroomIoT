<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许所有明文 HTTP 流量（适用于局域网测试） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- 信任系统预装的 CA 证书 -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
