<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootChangePwd"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarChangePwd"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:title="修改密码"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="原密码"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOldPwd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:longClickable="false"
                    android:textIsSelectable="false"
                    android:contextClickable="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="新密码"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNewPwd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:longClickable="false"
                    android:textIsSelectable="false"
                    android:contextClickable="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="确认新密码"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPwd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:longClickable="false"
                    android:textIsSelectable="false"
                    android:contextClickable="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 常驻密码强度区 (文字与指示条同行) -->
            <LinearLayout
                android:id="@+id/layoutStrength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="密码强度："
                    android:textSize="14sp"
                    android:textColor="#666666" />

                <View android:id="@+id/bar1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:background="#E0E0E0" android:layout_marginEnd="3dp"/>
                <View android:id="@+id/bar2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:background="#E0E0E0" android:layout_marginEnd="3dp"/>
                <View android:id="@+id/bar3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:background="#E0E0E0" android:layout_marginEnd="3dp"/>
                <View android:id="@+id/bar4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:background="#E0E0E0" android:layout_marginEnd="3dp"/>
                <View android:id="@+id/bar5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:background="#E0E0E0" android:layout_marginEnd="8dp"/>

                <!-- 强度文字移到右侧 -->
                <TextView
                    android:id="@+id/tvStrengthText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#BDBDBD" />
            </LinearLayout>

            <!-- 消息提示区 -->
            <LinearLayout
                android:id="@+id/layoutMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:visibility="gone">
                <ImageView android:id="@+id/ivMsgIcon" android:layout_width="20dp" android:layout_height="20dp" />
                <TextView android:id="@+id/tvMsgText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:textSize="14sp" />
            </LinearLayout>

            <!-- 确认按钮移到此处 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitPwd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="确认修改"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
